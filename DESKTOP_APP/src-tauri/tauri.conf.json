{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnemOS",
  "version": "1.0.0",
  "identifier": "dev.knemos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KnemOS",
        "width": 1300,
        "height": 840,
        "minWidth": 1000,
        "minHeight": 640,
        "decorations": false,
        "theme": "Dark",
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8765 ws://127.0.0.1:8765 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
